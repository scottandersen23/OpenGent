
generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

model Lead {
 id            String   @id @default(uuid())
 name          String
 email         String
 company       String?
 role          String?
 data_challenge String?
 data_stack    String?
 referrer      String?
 created_at    DateTime @default(now())
}
