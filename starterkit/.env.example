# Required
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/yourdb

# Optional: Slack notifications
SLACK_WEBHOOK_URL=

# Optional: AI summaries (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30

# OpenGent logical mappings (edit to match client schema)
TX_TABLE=transactions
TX_ID_COL=transaction_id
TX_DATE_COL=transaction_date
TX_AMOUNT_COL=amount

REVENUE_TABLE=daily_revenue
REV_DATE_COL=day
REV_AMOUNT_COL=revenue

# Sensible thresholds (tune per client)
FRESHNESS_MAX_HOURS=36
NULL_PCT_WARN=2.0
DUPES_WARN=0
REVENUE_DROP_PCT_WARN=15.0
